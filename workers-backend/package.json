{
  "name": "scalyo-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute scalyo-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute scalyo-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.60.0"
  }
}
